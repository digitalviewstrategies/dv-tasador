# DV Tasador — backend. Copiá a .env y completá. NO commitear el .env real.

# --- Comparables (Apify) ---
APIFY_TOKEN=
ACTOR_ZONAPROP=epctex/zonaprop-scraper
ACTOR_MERCADOLIBRE=epctex/mercadolibre-scraper
# ACTOR_ARGENPROP=
# ACTOR_REMAX=

# --- Análisis de fotos (Claude visión) ---
ANTHROPIC_API_KEY=

# --- Captura de leads → La Base Viva (dbsuper) ---
# El lead del tasador entra como fila en la tabla `tasaciones` con estado 'a_captar'.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
LEADS_TABLE=tasaciones
# Webhook genérico opcional (además de Supabase): Make / Zapier / Sheets
LEAD_WEBHOOK_URL=
# Respaldo JSONL local (en Render free es efímero; el destino durable es Supabase)
DATA_DIR=./data

# --- Alerta de WhatsApp por cada lead 'a captar' ---
ALERT_WHATSAPP=5491170669425
# Reusá la WhatsApp Business API del bot DV (texto libre solo dentro de la ventana de 24h;
# fuera de eso Meta exige template aprobado):
WABA_TOKEN=
PHONE_NUMBER_ID=
# Fallback si no usás WABA: webhook a Make/Zapier que dispara el WhatsApp
ALERT_WEBHOOK_URL=

# --- Seguridad ---
# En producción restringí a tu dominio de Pages, ej: https://digitalviewstrategies.github.io
ALLOWED_ORIGINS=*
